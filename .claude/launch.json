{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "oubliette",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": [
        "-m",
        "oubliette.app.server"
      ],
      "port": 8000
    },
    {
      "name": "forge",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": [
        "-m",
        "oubliette.creator.server"
      ],
      "port": 8001
    },
    {
      "name": "preview-test",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "oubliette.app.server:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8055"
      ],
      "port": 8055,
      "env": {
        "OUBLIETTE_DB": "preview-test-save.sqlite",
        "OUBLIETTE_CONFIG": "preview-test-config.json"
      }
    },
    {
      "name": "forge-preview",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "oubliette.creator.server:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8012"
      ],
      "port": 8012
    },
    {
      "name": "preview-test-n3",
      "runtimeExecutable": ".venv/Scripts/python.exe",
      "runtimeArgs": [
        "-m",
        "uvicorn",
        "oubliette.app.server:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8056"
      ],
      "port": 8056,
      "env": {
        "OUBLIETTE_DB": "preview-test-save-n3.sqlite",
        "OUBLIETTE_CONFIG": "preview-test-config.json"
      }
    }
  ]
}