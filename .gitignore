__pycache__/
*.py[cod]
.venv/
venv/

# Private Python runtime downloaded by setup.bat when the computer has none.
.pyruntime/
pyruntime.tar.gz
*.egg-info/
.pytest_cache/
.env
*.sqlite
*.sqlite3
.DS_Store

# Release build area: the git-archive zips AND the local-only release.bat
# (the double-click release builder) both live here, gitignored on purpose.
dist/

# The Forge writes timestamped pack backups here before each save — local safety
# net, not shared history.
pack-backups/

# Personal/local Claude Code settings — not shared history
.claude/settings.local.json

# Combat handoff: the transient Arena→Oubliette result JSON (runtime output).
result.json

# Downloaded narrator voice models (models/kokoro/, models/qwen-1.7b/) — large
# binaries fetched per-player by setup's picker, never committed.
models/

# Per-run combat log dump (diagnostics; overwritten every fight).
arena/last_combat_log.txt

# Player-uploaded PC portraits — per-save runtime data, lives beside the save DB.
character-portraits/

# Transient SRD source dumps (fetched on demand by the generators, never committed).
srd-monsters-raw.json
srd-magic-items-raw.json
srd-rule-sections-raw.json

# Secrets — never commit
APIKey.txt
*.key
srd-spells-raw.json
# The player's local provider + API-key config (front-door "connect your AI").
# Plaintext, per-machine — must never enter shared history.
oubliette-config.json
preview-test-config.json

# Internal dev docs — kept out of the public repo. The always-current dev diary
# (PROJECT_NOTES.md, moved under docs/), the phase/roadmap plans, the candid
# DM/model interview feedback, and the internal docs index. The PUBLIC docs live
# at the repo root (README, FEATURES, ROADMAP) plus the design specs in docs/design/.
/docs/PROJECT_NOTES.md
/docs/roadmap/
/docs/feedback/
/docs/media/
/docs/README.md
/spike/
