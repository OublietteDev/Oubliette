__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.env
*.sqlite
*.sqlite3
.DS_Store

# The Forge writes timestamped pack backups here before each save — local safety
# net, not shared history.
pack-backups/

# Personal/local Claude Code settings — not shared history
.claude/settings.local.json

# The Arena's visual/audio assets (~100MB: tokens, music, sounds, fonts,
# backgrounds, animation frames) — live on disk for local play, never committed
# so git stays lean. Versioning strategy (lfs / one-time commit) deferred.
arena/assets/

# Combat handoff: the transient Arena→Oubliette result JSON (runtime output).
result.json

# Transient SRD source dumps (fetched on demand by the generators, never committed).
srd-monsters-raw.json
srd-magic-items-raw.json
srd-rule-sections-raw.json

# Secrets — never commit
APIKey.txt
*.key
